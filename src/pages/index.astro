---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Newsletter from '../components/Newsletter.astro';
import { SITE_TITLE, SITE_TAGLINE, SITE_DESCRIPTION, AUDIENCES } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => {
    // Pinned posts always come first
    if (a.data.pinned && !b.data.pinned) return -1;
    if (!a.data.pinned && b.data.pinned) return 1;
    // Otherwise newest first
    return b.data.publishDate.valueOf() - a.data.publishDate.valueOf();
  }
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const audienceLabel: Record<string, string> = Object.fromEntries(
  AUDIENCES.map((a) => [a.slug, a.label])
);
---

<Base title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section class="hero">
    <div class="measure">
      <h1>{SITE_TITLE}</h1>
      <p class="tagline">{SITE_TAGLINE}</p>
    </div>
  </section>

  <section class="filter measure" aria-label="Filter posts by audience">
    <div class="filter-bar" role="tablist">
      <button type="button" class="pill active" data-filter="all" role="tab" aria-selected="true">
        All
      </button>
      {
        AUDIENCES.map((a) => (
          <button
            type="button"
            class="pill"
            data-filter={a.slug}
            role="tab"
            aria-selected="false"
          >
            {a.label}
          </button>
        ))
      }
    </div>
  </section>

  <section class="posts measure">
    {
      posts.length === 0 ? (
        <p class="empty">First post is on the way. Check back soon.</p>
      ) : (
        <ul class="post-list">
          {posts.map((post) => (
            <li data-audiences={post.data.audiences.join(' ')}>
              <a class="card" href={`/blog/${post.data.slug}/`}>
                <div class="thumb">
                  <Image
                    src={post.data.heroImage}
                    alt={post.data.heroImageAlt}
                    width={480}
                    height={270}
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <div class="text">
                  <h2>{post.data.title}</h2>
                  <p class="meta">
                    <time datetime={post.data.publishDate.toISOString()}>
                      {fmt(post.data.publishDate)}
                    </time>
                    {post.data.audiences.length > 0 && (
                      <>
                        {' · '}
                        <span class="audiences">
                          {post.data.audiences.map((a) => audienceLabel[a]).join(', ')}
                        </span>
                      </>
                    )}
                  </p>
                  <p class="desc">{post.data.metaDescription}</p>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )
    }
    <p class="empty-filter" hidden>
      No posts in this audience yet. Try another, or check back soon.
    </p>
  </section>

  <div class="measure">
    <Newsletter source="homepage" />
  </div>
</Base>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.filter .pill');
  const items = document.querySelectorAll<HTMLLIElement>('.post-list li');
  const empty = document.querySelector<HTMLElement>('.empty-filter');

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      const filter = pill.dataset.filter || 'all';
      pills.forEach((p) => {
        p.classList.toggle('active', p === pill);
        p.setAttribute('aria-selected', p === pill ? 'true' : 'false');
      });

      let visible = 0;
      items.forEach((li) => {
        const audiences = (li.dataset.audiences || '').split(' ');
        const show = filter === 'all' || audiences.includes(filter);
        li.hidden = !show;
        if (show) visible++;
      });

      if (empty) empty.hidden = visible !== 0;
    });
  });
</script>

<style>
  .hero {
    padding: 3rem 0 1.5rem;
    border-bottom: 1px solid var(--c-rule);
    margin-bottom: 2rem;
  }
  .hero h1 {
    margin: 0 0 1rem;
    font-size: clamp(2.25rem, 5vw, 3.25rem);
  }
  .tagline {
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    line-height: 1.5;
    color: var(--c-muted);
    margin: 0;
  }
  .filter {
    margin-bottom: 1.5rem;
  }
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .pill {
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    padding: 0.4rem 0.9rem;
    background: var(--c-bg);
    color: var(--c-muted);
    border: 1px solid var(--c-rule);
    border-radius: 999px;
    cursor: pointer;
    transition:
      background 120ms,
      color 120ms,
      border-color 120ms;
  }
  .pill:hover {
    color: var(--c-ink);
    border-color: var(--c-ink);
  }
  .pill.active {
    background: var(--c-ink);
    color: var(--c-bg);
    border-color: var(--c-ink);
  }
  .posts {
    padding-bottom: 2rem;
  }
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .post-list li {
    border-bottom: 1px solid var(--c-rule);
  }
  .post-list li:last-child {
    border-bottom: 0;
  }
  .card {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 1.5rem;
    align-items: start;
    padding: 1.75rem 0;
    text-decoration: none;
    color: inherit;
  }
  .thumb {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 3px;
    background: var(--c-bg-alt);
  }
  .thumb :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 240ms ease;
  }
  .card:hover .thumb :global(img) {
    transform: scale(1.03);
  }
  .text h2 {
    margin: 0 0 0.35rem;
    font-size: 1.5rem;
    color: var(--c-ink);
    text-decoration: none;
  }
  .card:hover .text h2 {
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
  }
  .meta {
    color: var(--c-muted);
    font-size: 0.875rem;
    font-style: italic;
    margin: 0 0 0.5rem;
  }
  .audiences {
    font-style: normal;
  }
  .desc {
    margin: 0;
    color: var(--c-ink);
  }
  @media (max-width: 560px) {
    .card {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .thumb {
      max-width: 100%;
    }
  }
  .empty,
  .empty-filter {
    color: var(--c-muted);
    font-style: italic;
    text-align: center;
    padding: 2rem 0;
  }
</style>
