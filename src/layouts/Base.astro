---
// Base layout for non-post pages (home, about, contact, blog index).

import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  breadcrumbs?: { label: string; href: string }[];
  appendSiteTitle?: boolean;
}

const { title, description, ogImage, breadcrumbs, appendSiteTitle = true } = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      breadcrumbs={breadcrumbs}
      appendSiteTitle={appendSiteTitle}
    />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
