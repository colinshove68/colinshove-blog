---
import type { CollectionEntry } from 'astro:content';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Share from '../components/Share.astro';
import Newsletter from '../components/Newsletter.astro';
import Downloads from '../components/Downloads.astro';
import Comments from '../components/Comments.astro';
import { AUDIENCES } from '../consts';
import '../styles/global.css';

type Props = CollectionEntry<'blog'>['data'] & {
  readingTime?: string;
};

const {
  title,
  seoTitle,
  metaDescription,
  slug,
  publishDate,
  updatedDate,
  author,
  heroImage,
  heroImageAlt,
  primaryKeyword,
  secondaryKeywords,
  audiences,
  downloads,
  readingTime,
} = Astro.props;

const trail = [
  { label: 'Home', href: '/' },
  { label: title, href: `/blog/${slug}` },
];

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const audienceLabel: Record<string, string> = Object.fromEntries(
  AUDIENCES.map((a) => [a.slug, a.label])
);
---

<!doctype html>
<html lang="en-GB">
  <head>
    <SEO
      title={seoTitle}
      description={metaDescription}
      canonical={`/blog/${slug}/`}
      ogImage={heroImage.src}
      ogImageAlt={heroImageAlt}
      type="article"
      publishDate={publishDate}
      updatedDate={updatedDate}
      author={author}
      primaryKeyword={primaryKeyword}
      secondaryKeywords={secondaryKeywords}
      breadcrumbs={trail}
    />
  </head>
  <body>
    <Header />

    <main>
      <article>
        <div class="measure">
          <Breadcrumbs trail={trail} />

          <header class="post-head">
            <h1>{title}</h1>
            <p class="byline">
              By {author} ·
              <time datetime={publishDate.toISOString()}>{fmtDate(publishDate)}</time>
              {updatedDate && (
                <>
                  {' '}· Updated <time datetime={updatedDate.toISOString()}>{fmtDate(updatedDate)}</time>
                </>
              )}
              {readingTime && <> · {readingTime}</>}
            </p>
            {audiences.length > 0 && (
              <p class="audiences">
                For: {audiences.map((a) => audienceLabel[a]).join(', ')}
              </p>
            )}
          </header>
        </div>

        {
          heroImage && (
            <figure class="hero">
              <div class="measure-wide">
                <img
                  src={heroImage.src}
                  width={heroImage.width}
                  height={heroImage.height}
                  alt={heroImageAlt}
                  loading="eager"
                  decoding="async"
                />
              </div>
            </figure>
          )
        }

        <div class="measure post-body">
          <slot />
        </div>

        <div class="measure">
          <Downloads downloads={downloads} postSlug={slug} />
          <Share title={title} url={`/blog/${slug}/`} />
          <Newsletter
            heading="Get more like this"
            blurb="Posts straight to your inbox when they go live. No spam."
            source={`post:${slug}`}
          />
          <Comments pageId={slug} />
        </div>
      </article>
    </main>

    <Footer />

    <style>
      .post-head {
        margin: 1.5rem 0 2rem;
      }
      .byline {
        color: var(--c-muted);
        font-size: 0.9375rem;
        font-style: italic;
        margin: 0.5rem 0 0;
      }
      .audiences {
        color: var(--c-muted);
        font-size: 0.875rem;
        margin: 0.5rem 0 0;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .hero {
        margin: 2rem 0;
      }
      .hero img {
        width: 100%;
        height: auto;
        border-radius: 2px;
      }
      .post-body :global(p),
      .post-body :global(ul),
      .post-body :global(ol) {
        margin-bottom: 1.25rem;
      }
    </style>
  </body>
</html>
