---
// Renders all meta tags, Open Graph, Twitter Card, and JSON-LD schema for a page.
// Drop this into every layout to enforce Visibility Spec SEO on every page.

import { SITE_TITLE, SITE_URL, AUTHOR, DEFAULT_OG_IMAGE } from '../consts';

interface Props {
  title: string;
  description: string;
  appendSiteTitle?: boolean;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
  type?: 'website' | 'article';
  publishDate?: Date;
  updatedDate?: Date;
  author?: string;
  primaryKeyword?: string;
  secondaryKeywords?: string[];
  breadcrumbs?: { label: string; href: string }[];
}

const {
  title,
  description,
  appendSiteTitle = true,
  canonical = Astro.url.pathname,
  ogImage = DEFAULT_OG_IMAGE,
  ogImageAlt,
  type = 'website',
  publishDate,
  updatedDate,
  author = AUTHOR.name,
  primaryKeyword,
  secondaryKeywords = [],
  breadcrumbs = [],
} = Astro.props;

const canonicalURL = new URL(canonical, SITE_URL).toString();
const ogImageURL = new URL(ogImage, SITE_URL).toString();

// Compose keywords meta (Google ignores it, Bing still reads it occasionally)
const keywordsList = [primaryKeyword, ...secondaryKeywords].filter(Boolean).join(', ');

// JSON-LD: Person (used across the site)
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: AUTHOR.name,
  url: AUTHOR.url,
  jobTitle: AUTHOR.jobTitle,
  worksFor: { '@type': 'Organization', name: AUTHOR.worksFor, url: AUTHOR.worksForUrl },
  sameAs: AUTHOR.sameAs,
};

// JSON-LD: BlogPosting / Article (for posts)
const articleSchema =
  type === 'article' && publishDate
    ? {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description,
        image: ogImageURL,
        datePublished: publishDate.toISOString(),
        dateModified: (updatedDate ?? publishDate).toISOString(),
        author: { '@type': 'Person', name: author, url: AUTHOR.url },
        publisher: { '@type': 'Person', name: AUTHOR.name, url: AUTHOR.url },
        mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL },
        keywords: keywordsList,
      }
    : null;

// JSON-LD: BreadcrumbList
const breadcrumbSchema =
  breadcrumbs.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbs.map((b, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: b.label,
          item: new URL(b.href, SITE_URL).toString(),
        })),
      }
    : null;
---

<!-- Primary meta -->
<title>{appendSiteTitle ? `${title} | ${SITE_TITLE}` : title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
{keywordsList && <meta name="keywords" content={keywordsList} />}
<meta name="author" content={author} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={ogImageURL} />
{ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
<meta property="og:site_name" content={SITE_TITLE} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />

<!-- Article dates -->
{publishDate && <meta property="article:published_time" content={publishDate.toISOString()} />}
{updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}

<!-- JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
{articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}
{breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}

<!-- Standard housekeeping -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href={new URL('rss.xml', SITE_URL).toString()} />
