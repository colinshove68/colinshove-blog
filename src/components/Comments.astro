---
// Giscus comments component. Loads from giscus.app, uses GitHub Discussions
// as the backend. Free, no tracking, no ads.
//
// Setup:
// 1. Enable Discussions on your repo (Settings > General > scroll to Features)
// 2. Install the giscus app: https://github.com/apps/giscus
// 3. Visit https://giscus.app to generate config values
// 4. Paste those values into src/consts.ts under the GISCUS export
// 5. Set GISCUS.enabled = true

import { GISCUS } from '../consts';

const { enabled, repo, repoId, category, categoryId, mapping, reactionsEnabled, emitMetadata, inputPosition, theme, lang } = GISCUS;
---

{
  enabled && (
    <section class="comments" aria-label="Comments">
      <h2>Comments</h2>
      <p class="note">
        Comments are powered by GitHub Discussions. A GitHub account is needed
        to reply, which keeps the conversation civil and spam-free.
      </p>
      <script
        src="https://giscus.app/client.js"
        data-repo={repo}
        data-repo-id={repoId}
        data-category={category}
        data-category-id={categoryId}
        data-mapping={mapping}
        data-strict="0"
        data-reactions-enabled={reactionsEnabled}
        data-emit-metadata={emitMetadata}
        data-input-position={inputPosition}
        data-theme={theme}
        data-lang={lang}
        crossorigin="anonymous"
        async
      />
    </section>
  )
}

<style>
  .comments {
    margin: 4rem 0 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--c-rule);
  }
  .comments h2 {
    margin: 0 0 0.5rem;
  }
  .note {
    color: var(--c-muted);
    font-size: 0.9rem;
    font-style: italic;
    margin: 0 0 1.5rem;
  }
</style>
