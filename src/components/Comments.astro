---
// HyvorTalk comments. No login required for readers. They type
// a name, email, and message. Free up to 5k page views per month.
//
// Setup:
// 1. Sign up at https://talk.hyvor.com/
// 2. Add colinshove.com as a Website. Note the numeric Website ID.
// 3. In src/consts.ts under HYVORTALK, set enabled: true and paste
//    the websiteId.

import { HYVORTALK } from '../consts';

interface Props {
  pageId: string;
}

const { pageId } = Astro.props;
const { enabled, websiteId } = HYVORTALK;
const isConfigured =
  enabled && websiteId && !websiteId.includes('REPLACE');
---

{
  isConfigured && (
    <section class="comments" aria-label="Comments">
      <h2>Comments</h2>
      <p class="note">
        Type your name, email, and message. No account needed.
      </p>
      <script
        async
        type="module"
        src="https://talk.hyvor.com/embed/embed.js"
      />
      <hyvor-talk-comments website-id={websiteId} page-id={pageId} />
    </section>
  )
}

<style>
  .comments {
    margin: 4rem 0 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--c-rule);
  }
  .comments h2 {
    margin: 0 0 0.5rem;
  }
  .note {
    color: var(--c-muted);
    font-size: 0.9rem;
    font-style: italic;
    margin: 0 0 1.5rem;
  }
</style>
